{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rebecca.local/schemas/cli/v1/error.schema.json",
  "title": "Rebecca CLI API v1 error envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_version",
    "kind",
    "command",
    "payload_kind",
    "generated_at_unix_seconds",
    "error"
  ],
  "properties": {
    "api_version": {
      "const": "rebecca.cli.v1"
    },
    "kind": {
      "const": "error"
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "payload_kind": {
      "$ref": "payloads.schema.json#/$defs/payloadKind"
    },
    "generated_at_unix_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "error": {
      "$ref": "#/$defs/error"
    }
  },
  "$defs": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "title",
        "detail",
        "exit_code"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        },
        "exit_code": {
          "type": "integer",
          "minimum": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
