{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rebecca.local/schemas/cli/v1/payloads.schema.json",
  "title": "Rebecca CLI API v1 payload families",
  "type": "object",
  "$defs": {
    "payloadKind": {
      "type": "string",
      "enum": [
        "active-process-diagnostic",
        "app-leftovers-cleanup-plan",
        "cache-purge-report",
        "cleanup-plan",
        "config-paths",
        "history-list",
        "permissions-diagnostic",
        "project-artifact-catalog",
        "project-artifact-cleanup-plan",
        "rule-catalog"
      ]
    },
    "estimateSource": {
      "type": "string",
      "enum": [
        "unknown",
        "fresh-scan",
        "scan-cache",
        "not-measured"
      ]
    },
    "targetStatus": {
      "type": "string",
      "enum": [
        "allowed",
        "skipped",
        "blocked",
        "failed",
        "completed"
      ]
    },
    "cleanupIssueReason": {
      "type": "string",
      "enum": [
        "safety-opt-in-required",
        "warning-gate-required",
        "target-discovery-skipped",
        "target-discovery-failed",
        "duplicate-target-path",
        "safety-policy-skipped",
        "execution-target-missing",
        "safety-policy-blocked",
        "project-artifact-recently-modified",
        "reclaim-limit-satisfied",
        "scan-failed",
        "execution-failed",
        "unclassified"
      ]
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "cleanupIssueSummary": {
      "type": "object",
      "required": [
        "status",
        "reason_code",
        "targets",
        "estimated_bytes"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/targetStatus"
        },
        "reason_code": {
          "$ref": "#/$defs/cleanupIssueReason"
        },
        "targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "estimated_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "cleanupWarningSummary": {
      "type": "object",
      "required": [
        "warning",
        "targets",
        "estimated_bytes"
      ],
      "properties": {
        "warning": {
          "type": "string",
          "minLength": 1
        },
        "targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "estimated_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "cleanupSummary": {
      "type": "object",
      "required": [
        "total_targets",
        "allowed_targets",
        "skipped_targets",
        "blocked_targets",
        "failed_targets",
        "completed_targets",
        "estimated_bytes",
        "freed_bytes",
        "pending_reclaim_bytes",
        "issue_matrix",
        "warning_matrix"
      ],
      "properties": {
        "total_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "allowed_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "skipped_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "blocked_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "failed_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "completed_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "estimated_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "freed_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "pending_reclaim_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "issue_matrix": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cleanupIssueSummary"
          }
        },
        "warning_matrix": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cleanupWarningSummary"
          }
        }
      },
      "additionalProperties": false
    },
    "activeProcessMatch": {
      "type": "object",
      "required": [
        "process_id",
        "executable_name",
        "warning",
        "rule_ids"
      ],
      "properties": {
        "process_id": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "executable_name": {
          "type": "string",
          "minLength": 1
        },
        "warning": {
          "type": "string",
          "minLength": 1
        },
        "rule_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "activeProcessDiagnostic": {
      "type": "object",
      "required": [
        "platform",
        "platform_supported",
        "process_inspection_available",
        "matches",
        "unavailable_reason"
      ],
      "properties": {
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "platform_supported": {
          "type": "boolean"
        },
        "process_inspection_available": {
          "type": "boolean"
        },
        "matches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/activeProcessMatch"
          }
        },
        "unavailable_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
