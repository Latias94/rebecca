{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rebecca.local/schemas/cli/v1/payloads.schema.json",
  "title": "Rebecca CLI API v1 payload families",
  "type": "object",
  "$defs": {
    "payloadKind": {
      "type": "string",
      "enum": [
        "active-process-diagnostic",
        "app-leftovers-cleanup-plan",
        "cache-purge-report",
        "cleanup-plan",
        "config-paths",
        "history-list",
        "permissions-diagnostic",
        "project-artifact-catalog",
        "project-artifact-cleanup-plan",
        "project-artifact-insight",
        "rule-catalog"
      ]
    },
    "estimateSource": {
      "type": "string",
      "enum": [
        "unknown",
        "fresh-scan",
        "scan-cache",
        "not-measured"
      ]
    },
    "targetStatus": {
      "type": "string",
      "enum": [
        "allowed",
        "skipped",
        "blocked",
        "failed",
        "completed"
      ]
    },
    "cleanupIssueReason": {
      "type": "string",
      "enum": [
        "safety-opt-in-required",
        "warning-gate-required",
        "target-discovery-skipped",
        "target-discovery-failed",
        "duplicate-target-path",
        "safety-policy-skipped",
        "execution-target-missing",
        "safety-policy-blocked",
        "project-artifact-recently-modified",
        "reclaim-limit-exceeded",
        "scan-failed",
        "execution-failed",
        "unclassified"
      ]
    },
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "cleanupIssueSummary": {
      "type": "object",
      "required": [
        "status",
        "reason_code",
        "targets",
        "estimated_bytes"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/targetStatus"
        },
        "reason_code": {
          "$ref": "#/$defs/cleanupIssueReason"
        },
        "targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "estimated_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "cleanupWarningSummary": {
      "type": "object",
      "required": [
        "warning",
        "targets",
        "estimated_bytes"
      ],
      "properties": {
        "warning": {
          "type": "string",
          "minLength": 1
        },
        "targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "estimated_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "cleanupSummary": {
      "type": "object",
      "required": [
        "total_targets",
        "allowed_targets",
        "skipped_targets",
        "blocked_targets",
        "failed_targets",
        "completed_targets",
        "estimated_bytes",
        "freed_bytes",
        "pending_reclaim_bytes",
        "issue_matrix",
        "warning_matrix"
      ],
      "properties": {
        "total_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "allowed_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "skipped_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "blocked_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "failed_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "completed_targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "estimated_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "freed_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "pending_reclaim_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "issue_matrix": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cleanupIssueSummary"
          }
        },
        "warning_matrix": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cleanupWarningSummary"
          }
        }
      },
      "additionalProperties": false
    },
    "activeProcessMatch": {
      "type": "object",
      "required": [
        "process_id",
        "executable_name",
        "warning",
        "rule_ids"
      ],
      "properties": {
        "process_id": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "executable_name": {
          "type": "string",
          "minLength": 1
        },
        "warning": {
          "type": "string",
          "minLength": 1
        },
        "rule_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "activeProcessDiagnostic": {
      "type": "object",
      "required": [
        "platform",
        "platform_supported",
        "process_inspection_available",
        "matches",
        "unavailable_reason"
      ],
      "properties": {
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "platform_supported": {
          "type": "boolean"
        },
        "process_inspection_available": {
          "type": "boolean"
        },
        "matches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/activeProcessMatch"
          }
        },
        "unavailable_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "projectArtifactDiscoveryDiagnostic": {
      "type": "object",
      "required": [
        "kind",
        "path",
        "detail"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "root-missing",
            "root-metadata-read-skipped",
            "root-not-directory",
            "reparse-point-skipped",
            "directory-read-skipped",
            "directory-entry-read-skipped",
            "metadata-read-skipped"
          ]
        },
        "path": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "projectArtifactInsightTotal": {
      "type": "object",
      "required": [
        "key",
        "label",
        "targets",
        "estimated_bytes"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "targets": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "estimated_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        }
      },
      "additionalProperties": false
    },
    "projectArtifactInsightTarget": {
      "type": "object",
      "required": [
        "rule_id",
        "artifact",
        "path",
        "project_root",
        "status",
        "estimated_bytes",
        "estimate_source",
        "reason"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "project_root": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/$defs/targetStatus"
        },
        "estimated_bytes": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "estimate_source": {
          "$ref": "#/$defs/estimateSource"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "projectArtifactInsight": {
      "type": "object",
      "required": [
        "roots",
        "summary",
        "totals_by_root",
        "totals_by_project",
        "totals_by_artifact",
        "top_targets",
        "discovery_diagnostics"
      ],
      "properties": {
        "roots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "$ref": "#/$defs/cleanupSummary"
        },
        "totals_by_root": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projectArtifactInsightTotal"
          }
        },
        "totals_by_project": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projectArtifactInsightTotal"
          }
        },
        "totals_by_artifact": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projectArtifactInsightTotal"
          }
        },
        "top_targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projectArtifactInsightTarget"
          }
        },
        "discovery_diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/projectArtifactDiscoveryDiagnostic"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
